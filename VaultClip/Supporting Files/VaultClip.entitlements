<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Required for Keychain access under Hardened Runtime (ad-hoc and Developer ID).
	  With ad-hoc signing AppIdentifierPrefix is empty, so the group resolves to
	  the bundle id (VaultClip).
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(CFBundleIdentifier)</string>
	</array>
	<!--
	  Required for ad-hoc / local builds: CocoaPods frameworks are signed
	  separately from the main app. Without this, dyld rejects them under
	  Hardened Runtime (different Team IDs). Developer ID release builds
	  signed with the same Team ID for all embedded frameworks can omit this.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
