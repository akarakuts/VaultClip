    "accessibility.paste_blocked_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip needs Accessibility to paste into other apps with ⌘V.\n\nOpen System Settings → Privacy & Security → Accessibility, enable VaultClip, then try again. Install the app to /Applications and keep a single copy to avoid macOS resetting the permission."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip нужен Универсальный доступ для вставки ⌘V в другие приложения.\n\nОткройте Системные настройки → Конфиденциальность и безопасность → Универсальный доступ, включите VaultClip и попробуйте снова. Установите приложение в /Applications и держите одну копию, чтобы macOS не сбрасывал разрешение."
          }
        }
      }
    },
    "accessibility.paste_blocked_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accessibility permission required"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нужно разрешение Универсального доступа"
          }
        }
      }
    },
    "accessibility.required_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip needs Accessibility to paste into other apps (⌘V simulation) and to monitor some system events.\n\n1. Install VaultClip to /Applications (not from the DMG directly).\n2. Open System Settings → Privacy & Security → Accessibility.\n3. Enable VaultClip, then quit and reopen the app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip нужен Универсальный доступ для вставки в другие приложения (имитация ⌘V) и отслеживания части системных событий.\n\n1. Установите VaultClip в /Applications (не запускайте с DMG).\n2. Откройте Системные настройки → Конфиденциальность и безопасность → Универсальный доступ.\n3. Включите VaultClip, затем завершите и снова откройте приложение."
          }
        }
      }
    },
