    "encryption.decrypt_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip found encrypted history but no matching encryption key. This can happen after an interrupted update or if the Keychain entry was removed.\n\nQuit and restore ~/Library/Application Support/com.karakuts.VaultClip from a backup, or start with an empty history."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip нашёл зашифрованную историю, но нет подходящего ключа. Так бывает после прерванного обновления или удаления записи из Связки ключей.\n\nЗавершите работу и восстановите ~/Library/Application Support/com.karakuts.VaultClip из резервной копии или начните с пустой истории."
          }
        }
      }
    },
