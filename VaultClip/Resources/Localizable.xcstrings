    "install.transient_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are running VaultClip from a disk image or temporary folder. macOS resets Accessibility permission when the app path changes.\n\nDrag VaultClip to Applications and launch it from there for stable permissions and login at startup."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip запущен с образа диска или из временной папки. macOS сбрасывает разрешение Универсального доступа при смене пути.\n\nПеретащите VaultClip в Applications и запускайте оттуда — так разрешения и автозапуск будут стабильнее."
          }
        }
      }
    },
