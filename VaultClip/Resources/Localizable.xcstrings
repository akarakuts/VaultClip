    "about.info_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip — GNU GPL v3 or later.\nBased on Yippy by Matthew Davidson (MIT), https://github.com/mattDavo/Yippy\nFork and modifications: Aleksey Karakuts — aleksey@karakuts.com\nhttps://github.com/akarakuts/VaultClip"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultClip — GNU GPL v3 или новее.\nНа основе Yippy Matthew Davidson (MIT), https://github.com/mattDavo/Yippy\nФорк и доработки: Aleksey Karakuts — aleksey@karakuts.com\nhttps://github.com/akarakuts/VaultClip"
          }
        }
      }
    },
    "about.version" : {
